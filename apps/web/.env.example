APP_RUNTIME="front"
API_BASE_URL="https://api.les-extras.com/api"
NEXT_PUBLIC_API_URL="https://api.les-extras.com/api"
# Must match apps/api JWT_SECRET — used by middleware to verify admin cookies
JWT_SECRET="change-this-secret"
# Independent secret for wrapping front-user session cookies (lesextras_session)
# Must be a long random string, different from JWT_SECRET
SESSION_SECRET="change-this-to-a-different-secret"
DEMO_USER_PASSWORD="password123"
