generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ESTABLISHMENT
  FREELANCE
  ADMIN
}

enum UserStatus {
  PENDING
  VERIFIED
  BANNED
}

enum ReliefMissionStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum ServiceStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ServiceType {
  WORKSHOP
  TRAINING
}

enum PricingType {
  SESSION
  PER_PARTICIPANT
  QUOTE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum ReviewType {
  ESTABLISHMENT_TO_FREELANCE
  FREELANCE_TO_ESTABLISHMENT
}

enum DocumentType {
  AVATAR
  SERVICE_PHOTO
  IDENTITY_DOC
  OTHER
}

// ─────────────────────────────────────────────
// CORE IDENTITY
// ─────────────────────────────────────────────

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  password       String
  role           UserRole
  status         UserStatus @default(PENDING)
  onboardingStep Int        @default(0)
  isAvailable    Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  profile               Profile?
  establishmentMissions ReliefMission[] @relation("EstablishmentMissions")
  ownerServices         Service[]       @relation("OwnerServices")
  establishmentBookings Booking[]       @relation("EstablishmentBookings")
  freelanceBookings     Booking[]       @relation("FreelanceBookings")
  sentMessages          Message[]       @relation("SentMessages")
  receivedMessages      Message[]       @relation("ReceivedMessages")
  conversationsAsA      Conversation[]  @relation("ConversationParticipantA")
  conversationsAsB      Conversation[]  @relation("ConversationParticipantB")
  notifications         Notification[]
  reviewsAuthored       Review[]        @relation("ReviewsAuthored")
  reviewsReceived       Review[]        @relation("ReviewsReceived")
  documents             Document[]
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  firstName      String
  lastName       String
  bio            String?
  avatar         String?
  jobTitle       String?
  phone          String?
  address        String?
  city           String?
  zipCode        String?
  country        String?
  skills         String[] @default([])
  diplomaUrl     String?
  companyName    String?
  siret          String?
  tvaNumber      String?
  onboardingStep Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────────

model Conversation {
  id             String   @id @default(cuid())
  participantAId String
  participantBId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participantAUser User      @relation("ConversationParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantBUser User      @relation("ConversationParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages         Message[]

  @@unique([participantAId, participantBId])
  @@index([participantAId])
  @@index([participantBId])
}

model Message {
  id             String   @id @default(cuid())
  content        String
  senderId       String
  receiverId     String
  conversationId String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  sender       User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User          @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  type      String // INFO, SUCCESS, WARNING
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PILIER 1 — RENFORT (ReliefMission)
// ─────────────────────────────────────────────

model ReliefMission {
  id                 String              @id @default(cuid())
  title              String
  dateStart          DateTime
  dateEnd            DateTime
  hourlyRate         Float
  status             ReliefMissionStatus @default(OPEN)
  address            String
  metier             String?
  shift              String? // "JOUR" | "NUIT"
  city               String?
  zipCode            String?
  description        String?             @db.Text
  requiredSkills     String[]
  establishmentType  String?
  targetPublic       String[]            @default([])
  unitSize           String?
  slots              Json?
  diplomaRequired    Boolean?            @default(false)
  hasTransmissions   Boolean?            @default(false)
  transmissionTime   String?
  perks              String[]            @default([])
  exactAddress       String?
  accessInstructions String?             @db.Text

  establishmentId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  establishment User      @relation("EstablishmentMissions", fields: [establishmentId], references: [id], onDelete: Restrict)
  bookings      Booking[]

  @@index([establishmentId])
}

// ─────────────────────────────────────────────
// PILIER 2 — ATELIERS (Service)
// ─────────────────────────────────────────────

model Service {
  id              String  @id @default(cuid())
  title           String
  description     String?
  price           Float   @default(0)
  capacity        Int     @default(10)
  durationMinutes Int     @default(120)
  category        String?

  type                ServiceType @default(WORKSHOP)
  pricingType         PricingType @default(SESSION)
  publicCible         String[]    @default([])
  slots               Json?
  pricePerParticipant Float?
  materials           String?
  objectives          String?     @db.Text
  methodology         String?     @db.Text
  evaluation          String?     @db.Text

  status ServiceStatus @default(ACTIVE)

  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User       @relation("OwnerServices", fields: [ownerId], references: [id], onDelete: Restrict)
  bookings  Booking[]
  documents Document[]

  @@index([ownerId])
}

// ─────────────────────────────────────────────
// RÉSERVATIONS & CANDIDATURES (Booking)
// ─────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING) // Paiement manuel
  message       String?
  scheduledAt   DateTime      @default(now())

  // Champs spécifiques aux candidatures (Renfort)
  proposedRate Float?

  // Champs spécifiques aux ateliers
  nbParticipants Int?

  establishmentId String // Celui qui réserve/qui crée la mission
  freelanceId     String? // Celui qui postule/ou anime l'atelier
  reliefMissionId String?
  serviceId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  establishment User           @relation("EstablishmentBookings", fields: [establishmentId], references: [id], onDelete: Restrict)
  freelance     User?          @relation("FreelanceBookings", fields: [freelanceId], references: [id], onDelete: SetNull)
  reliefMission ReliefMission? @relation(fields: [reliefMissionId], references: [id], onDelete: SetNull)
  service       Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  invoice       Invoice?
  reviews       Review[]

  @@index([establishmentId])
  @@index([freelanceId])
  @@index([reliefMissionId])
  @@index([serviceId])
}

// ─────────────────────────────────────────────
// FACTURATION (Invoice)
// ─────────────────────────────────────────────

model Invoice {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  amount        Float
  status        String   @default("UNPAID")
  invoiceNumber String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// AVIS
// ─────────────────────────────────────────────

model Review {
  id        String     @id @default(cuid())
  bookingId String
  authorId  String
  targetId  String
  rating    Int
  comment   String?
  type      ReviewType
  createdAt DateTime   @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author  User    @relation("ReviewsAuthored", fields: [authorId], references: [id])
  target  User    @relation("ReviewsReceived", fields: [targetId], references: [id])

  @@unique([bookingId, authorId])
  @@index([targetId])
  @@index([authorId])
}

// ─────────────────────────────────────────────
// DOCUMENTS / UPLOADS
// ─────────────────────────────────────────────

model Document {
  id        String       @id @default(cuid())
  type      DocumentType @default(OTHER)
  url       String
  filename  String
  mimeType  String?
  sizeBytes Int?
  userId    String?
  serviceId String?
  createdAt DateTime     @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([serviceId])
}
